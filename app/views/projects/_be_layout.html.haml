#carousel-BE.carousel.slide{"data-ride" => "carousel"}

  %ol.carousel-indicators
    %li.active{"data-slide-to" => "0", "data-target" => "#carousel-BE"}
    %li{"data-slide-to" => "1", "data-target" => "#carousel-BE"}
    %li{"data-slide-to" => "2", "data-target" => "#carousel-BE"}
    %li{"data-slide-to" => "3", "data-target" => "#carousel-BE"}
	
  .carousel-inner
    .item.active= image_tag "/assets/content/BE/landing-slide.png"
    .item= image_tag "/assets/content/BE/Product-list-slide.png"
    .item= image_tag "/assets/content/BE/Product-show-slide.png"
    .item= image_tag "/assets/content/BE/cart-slide.png"
	
  %a.left.carousel-control{"data-slide" => "prev", href: "#carousel-BE"}
    %span.glyphicon.glyphicon-chevron-left
  %a.right.carousel-control{"data-slide" => "next", href: "#carousel-BE"}
    %span.glyphicon.glyphicon-chevron-right