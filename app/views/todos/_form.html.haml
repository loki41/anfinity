= form_for @todo do |f|
  - if @todo.errors.any?
    #error_explanation
      %h2= "#{pluralize(@todo.errors.count, "error")} prohibited this todo from being saved:"
      %ul
        - @todo.errors.full_messages.each do |msg|
          %li= msg

  .field
    = f.label :name
    = f.text_field :name
  .field
    = f.label :kind, "Type"
    = f.select :kind, ["New Feature", "New Section", "Technical Update", "Bug", "New Content", "Design Update", "Redesign"]
  .field
    = f.label :location
    = f.select :location, ["Under the hood", "New Section", "Portfolio", "About", "Blog", "Cook Book", "Contact"]
  .field
    = f.label :status
    = f.select :status, ["Pending", "In Progress", "Complete", "Cancelled"]
  .field
    = f.label :due
    = f.date_select :due
  .actions
    = f.submit 'Save'
