- meta :title => "Anfinity Cookbook",
	   :description => "The Anfinity cookbook, a place to store and share recipes with the world. A place to show off my other interests out side of web design and development",
       :keywords => %w(Anfinity cookbook recipes AnthonyMcLaughlin Anthony's Duck Confit Crab Cakes)

.row#recipes
  - @recipes.each do |recipe|
    .col-md-3.rbox
      = link_to recipe_path(recipe) do	  
        .content-recipe-img
          - if File.exist? "#{Rails.public_path}/assets/recipes/#{recipe.name.parameterize}.jpg"
            = image_tag "/assets/recipes/#{recipe.name.parameterize}.jpg"
          - else
            = image_tag "/assets/recipes/no-image2.png"
          .recipe-more-box
            .rmbl= "+"
        .content-recipe-info= recipe.name

%p

- if user_signed_in?
  .btn.btn-primary
    = link_to 'Add new recipe', new_recipe_path
	
#paging= will_paginate @recipes

