#nav{style: "#{project_index? ? 'display: none' : ''}"}
  .container
    .nav-logo= image_tag('anfinity-logo-white.png')
    - if project_index?
      .navi-menu.col-sm-10.col-md-10
        %ul.nav
          %li#navl-home.nav-item.active= link_to "Home", '#background'
          %li#navl-about.nav-item= link_to "About", '#about_area'
          %li#navl-projects.nav-item= link_to "Portfolio", '#projects_area'
          %li#navl-contact.nav-item= link_to "Contact", '#contact_area'

    - else
      .navi-menu.col-sm-10.col-md-10
        %ul.nav
          %li.nav-item{class: "#{@tab == 'home' ? 'active' : ''}"}=      link_to "Home",      root_path
          %li.nav-item{class: "#{@tab == 'about' ? 'active' : ''}"}=     link_to "About",     root_path(:anchor => "about_area")
          %li.nav-item{class: "#{@tab == 'portfolio' ? 'active' : ''}"}= link_to "Portfolio", root_path(:anchor => "projects_area")
          %li.nav-item{class: "#{@tab == 'contact' ? 'active' : ''}"}=   link_to 'Contact',   root_path(:anchor => "contact_area")

    - if user_signed_in?
      .btn-group
        %button.btn.btn-default.dropdown-toggle{"data-toggle" => "dropdown", :type => "button"}
          = fa_icon "bars"
        %ul.dropdown-menu{:role => "menu"}
          %li= link_to 'blog',       posts_path
          %li= link_to 'cookbook',   recipes_path
          %li= link_to "Categories", categories_path
          %li= link_to "Topics",     topics_path
          %li= link_to "To Do List", todos_path
          %li.divider
            %li= link_to "Logout", destroy_user_session_path, method: :delete
