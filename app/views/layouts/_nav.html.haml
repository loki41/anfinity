#nav{style: "#{project_index? ? 'display: none' : ''}"}
  .container
    .nav-logo= image_tag('anfinity-logo-white.png')
    - if project_index?
      .navi-menu.col-sm-10.col-md-10
        #navl-home.nav-item{class: "#{active? 'projects'}"}=     "Home"
        #navl-about.nav-item{class: "#{active? 'pages'}"}=       "About"
        #navl-projects.nav-item{class: "#{active? 'projects'}"}= "Portfolio"
        //#navl-blog.nav-item{class: "#{active? 'posts'}"}=        link_to 'Blog',      posts_path
        #navl-contact.nav-item{class: "#{active? 'inquiries'}"}= 'Contact'

    - else
      .navi-menu.col-sm-10.col-md-10
        .nav-item{class: "#{active? 'projects'}"}=     link_to "Home",      root_path
        .nav-item{class: "#{active? 'pages'}"}=       link_to "About",  root_path(:anchor => "about_area")
        .nav-item{class: "#{active? 'projects'}"}= link_to "Portfolio", root_path(:anchor => "projects_area")
        //.nav-item{class: "#{active? 'posts'}"}=        link_to 'Blog',      posts_path
        .nav-item{class: "#{active? 'inquiries'}"}= link_to 'Contact',   root_path(:anchor => "contact_area")

    - if user_signed_in?
      .btn-group
        %button.btn.btn-default.dropdown-toggle{"data-toggle" => "dropdown", :type => "button"}
          = fa_icon "bars"
        %ul.dropdown-menu{:role => "menu"}
          %li= link_to "Categories", categories_path
          %li= link_to "Topics", topics_path
          %li= link_to "To Do List", todos_path
          %li.divider
            %li= link_to "Logout", destroy_user_session_path, method: :delete
