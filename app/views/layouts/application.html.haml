<!DOCTYPE html>
%html
  %head
    %title Anfinity!
    = stylesheet_link_tag("application", :media => "all")
    = javascript_include_tag("application")
    = csrf_meta_tags
    %meta{:content => "width=device-width, initial-scale=1.0", :name => "viewport"}
      = metamagic
      = favicon_link_tag 'favicon.ico'
  %body
    - if controller.action_name.to_s == "underconstruction"
      = yield
    - else
      .row
        .container
          #header.row
            .logo-box
              = image_tag('logo.png')
              .logo-text nfinty
            #beta-box
              = link_to post_path('gone-beta') do
                %span.c1 B
                %span.c2 E
                %span.c3 T
                %span.c4 A
            .nav-menu
              %ul.nav.nav-pills
                %li{class: "#{active? 'projects'}"}= 	link_to "portfolio", projects_path
                %li{class: "#{active? 'pages'}"}= 	 	link_to "about",     about_path
                %li{class: "#{active? 'posts'}"}= 		link_to 'blog',      posts_path
                %li{class: "#{active? 'recipes'}"}=  	link_to 'cookbook',  recipes_path
                %li{class: "#{active? 'inquiries'}"}= 	link_to 'contact',   new_inquiry_path
                - if user_signed_in?
                  %li{class: "#{active? 'projects'}"}= 	 link_to "Logout", destroy_user_session_path, method: :delete
                  %li{class: "#{active? 'categories'}"}= link_to "Categories", categories_path
                  %li{class: "#{active? 'topics'}"}= 	 link_to "Topics", topics_path
                  %li{class: "#{active? 'todos'}"}= 	 link_to "To Do List", todos_path
          %hr
            #portfolio
              .hide= render_breadcrumbs :separator => ' / '
              = yield
            %hr
              #footer .. and beyond
              = render 'layouts/footer'