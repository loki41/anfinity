<%= form_for(@post) do |f| %>
  <% if @post.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@post.errors.count, "error") %> prohibited this post from being saved:</h2>

      <ul>
      <% @post.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>
  <div class="field">
    <%= f.label :tag_list, "Tags (separated by commas)" %><br>
    <%= f.text_area :tag_list %>
  </div>
  
  <div class="field">
    <%= f.label :content %><br>
    <%= f.text_area :content %>
  </div>
  
  
  <div class="field">
    <%= f.label :topic %><br>
    <%= f.select :topic, Topic.all.collect { |t| [t.name, t.id] } %>
  </div>
  
  <div class="field">
    <%= f.label :category %><br>
    <%= f.select :category, Category.all.collect {|c| [c.name, c.id]} %>
  </div>
    
  <div class="field">
    <%= f.label :meta_title %><br>
    <%= f.text_field :meta_title %>
  </div>
  <div class="field">
    <%= f.label :meta_description %><br>
    <%= f.text_area :meta_description %>
  </div>
  <div class="field">
    <%= f.label :meta_keywords %><br>
    <%= f.text_field :meta_keywords %>
  </div>
  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>
