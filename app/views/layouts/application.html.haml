<!DOCTYPE html>
%html{lang: "en"}
  %head
    = stylesheet_link_tag("application", :media => "all")
    = javascript_include_tag("application")
    = csrf_meta_tags
    %meta{:content => "width=device-width, initial-scale=1.0", :name => "viewport"}
    = metamagic
    = favicon_link_tag 'favicon.ico'
  %body
    - if controller.action_name.to_s == "underconstruction"
      = yield
    - else
      - if params[:controller] == "projects" && controller.action_name.to_s == "index"
        #background

      .container
        = yield

      #footer
        = render 'layouts/footer'